<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="768.0" prefWidth="1024.0" style="-fx-background-color: #f4f4f9;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="whz.pti.controllers.HomePageController">

    <top>
        <HBox alignment="CENTER_RIGHT" prefHeight="50.0" style="-fx-background-color: #ffffff; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 2);" BorderPane.alignment="CENTER">
            <children>
                <Label fx:id="userStatusLabel" text="Angemeldet als: Ivan (Admin)">
                    <HBox.margin>
                        <Insets right="20.0" />
                    </HBox.margin>
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Label>
                <Button fx:id="logoutButton" mnemonicParsing="false" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Abmelden">
                    <HBox.margin>
                        <Insets right="20.0" />
                    </HBox.margin>
                </Button>
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="250.0" spacing="15.0" style="-fx-background-color: #2c3e50;" BorderPane.alignment="CENTER">
            <children>
                <Label text="Hausauswahl" textFill="#bdc3c7">
                    <font>
                        <Font size="12.0" />
                    </font>
                </Label>
                <ComboBox fx:id="houseComboBox" prefWidth="220.0" promptText="Haus wählen..." style="-fx-background-color: #34495e; -fx-text-fill: white;" />

                <VBox prefHeight="2.0" style="-fx-background-color: #34495e;" />

                <Label text="Räume" textFill="#bdc3c7">
                    <font>
                        <Font size="12.0" />
                    </font>
                </Label>
                <ListView fx:id="roomListView" prefHeight="400.0" prefWidth="220.0" style="-fx-background-color: #34495e; -fx-background-radius: 5;" />

                <VBox alignment="BOTTOM_CENTER" VBox.vgrow="ALWAYS">
                    <children>
                        <Button fx:id="settingsButton" mnemonicParsing="false" prefWidth="220.0" style="-fx-background-color: #16a085; -fx-text-fill: white;" text="Einstellungen ⚙" />
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets bottom="15.0" top="15.0" left="15.0" right="15.0" />
            </padding>
        </VBox>
    </left>

    <center>
        <VBox spacing="20.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" top="20.0" left="20.0" right="20.0" />
            </padding>
            <children>

                <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 1);">
                    <children>
                        <Label text="Schnellszenarien">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <HBox fx:id="scenariosContainer" spacing="10.0">
                            <children>
                                <Button mnemonicParsing="false" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="▶ Kino" />
                                <Button mnemonicParsing="false" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="▶ Haus verlassen" />
                                <Button mnemonicParsing="false" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="▶ Alles ausschalten" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Label fx:id="currentRoomLabel" text="Geräte im Raum: (Wählen Sie einen Raum)">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background-insets: 0;" VBox.vgrow="ALWAYS">
                            <content>
                                <TilePane fx:id="devicesTilePane" hgap="15.0" prefColumns="3" vgap="15.0" style="-fx-background-color: transparent;">
                                </TilePane>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

                <VBox prefHeight="180.0" spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 1);">
                    <children>
                        <Label text="Aktivitätsprotokoll (Letzte Ereignisse)">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>
                        <TableView fx:id="logTableView" prefHeight="130.0" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="timestampColumn" prefWidth="150.0" text="Zeitstempel" />
                                <TableColumn fx:id="deviceColumn" prefWidth="150.0" text="Gerät" />
                                <TableColumn fx:id="actionColumn" prefWidth="250.0" text="Aktion / Status" />
                                <TableColumn fx:id="userColumn" prefWidth="150.0" text="Benutzer" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

            </children>
        </VBox>
    </center>
</BorderPane>