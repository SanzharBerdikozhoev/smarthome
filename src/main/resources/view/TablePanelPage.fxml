<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<?import java.net.URL?>
<?import javafx.scene.layout.Region?>
<?import javafx.geometry.Insets?>
<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="700.0" prefWidth="1024.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="whz.pti.controllers.TablePanelPageController"
            styleClass="root">

    <stylesheets>
        <URL value="@../styles/TablePanelPage.css"/>
    </stylesheets>

    <top>
        <fx:include fx:id="header" source="./fragments/Header.fxml"/>
    </top>

    <left>
        <VBox prefWidth="240.0"
              spacing="10.0"
              styleClass="panel-sidebar">
            <Label
                    styleClass="panel-title"
                    text="Datenbank"/>
            <Label
                    styleClass="panel-subtitle"
                    text="TABELLEN"/>
            <Region prefHeight="6"/>
            <ListView fx:id="tablesListView"
                      VBox.vgrow="ALWAYS"
                      prefWidth="200.0"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="15.0"
              BorderPane.alignment="CENTER">

            <padding>
                <Insets left="20.0" right="20.0" top="20.0" bottom="20.0"/>
            </padding>

            <HBox alignment="CENTER_LEFT"
                  prefHeight="40.0"
                  prefWidth="200.0">
                <Label fx:id="labelCurrentTableName"
                       text="Wählen Sie eine Tabelle aus der Liste aus"/>
            </HBox>

            <VBox styleClass="content-card" VBox.vgrow="ALWAYS" spacing="15.0">
                <TableView fx:id="genericTable"
                           VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <HBox fx:id="actionButtonsContainer"
                      alignment="CENTER_RIGHT"
                      prefHeight="50.0"
                      spacing="12.0">
                    <Button fx:id="buttonAdd"
                            mnemonicParsing="false"
                            onAction="#handleAdd"
                            prefHeight="38.0"
                            prefWidth="120.0"
                            styleClass="action-button"
                            text="Hinzufügen"/>
                    <Button fx:id="buttonEdit"
                            mnemonicParsing="false"
                            onAction="#handleEdit"
                            prefHeight="38.0"
                            prefWidth="120.0"
                            styleClass="action-button"
                            text="Ändern"/>
                    <Button fx:id="buttonDelete"
                            mnemonicParsing="false"
                            onAction="#handleDelete"
                            prefHeight="38.0"
                            prefWidth="120.0"
                            styleClass="action-button"
                            text="Löschen"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
